generator client {
  provider        = "prisma-client-js"
  output          = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  category    String   @default("General")
  status      String   @default("active")
  imageUrl    String
  link        String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  erpTransactions ErpTransaction[]
}

model BoardMember {
  id        String   @id @default(cuid())
  name      String   @unique
  role      String
  bio       String?  @db.Text
  imageUrl  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id        String   @id @default(cuid())
  year      Int
  title     String
  category  String
  fileUrl   String
  isVerified Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  status    String   @default("active")
  createdAt DateTime @default(now())
}

model Donation {
  id              String   @id @default(cuid())
  amount          Float
  currency        String
  status          String
  donorEmail      String
  stripeSessionId String   @unique
  createdAt       DateTime @default(now())
}

model ContactInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  status    String   @default("new")
  createdAt DateTime @default(now())
}

model Newsletter {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  publishedAt DateTime
  excerpt     String   @db.Text
  content     String   @db.Text
  imageUrl    String
  fileUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum TransactionType {
  CASH
  IN_KIND
}

enum TransactionCategory {
  NUTRITION
  SALARY
  CONSTRUCTION
  UTILITIES
  SUPPLIES
  REVENUE
}

enum StudentStatus {
  ACTIVE
  GRADUATED
  DROPPED
  PROSPECTIVE
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  BROKEN
}

enum FundRestriction {
  UNRESTRICTED
  RESTRICTED
}

enum JournalEntryType {
  DEBIT
  CREDIT
}

enum TransactionStatus {
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
}

enum DonationSource {
  STRIPE
  BANK_TRANSFER
  CASH
  IN_KIND
}

model Student {
  id             String        @id @default(cuid())
  firstName      String
  lastName       String
  dateOfBirth    DateTime
  gender         String
  enrollmentDate DateTime      @default(now())
  status         StudentStatus @default(ACTIVE)
  bio            String?       @db.Text
  school         String        @default("Denbi")
  healthRecords  HealthRecord[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model ErpAccount {
  id             String            @id @default(cuid())
  name           String            @unique
  code           String            @unique
  balance        Decimal           @db.Decimal(12, 2) @default(0)
  journalEntries ErpJournalEntry[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model ErpTransaction {
  id              String            @id @default(cuid())
  type            TransactionType
  category        TransactionCategory
  status          TransactionStatus @default(PENDING_VERIFICATION)
  source          DonationSource    @default(CASH)
  description     String
  date            DateTime          @default(now())
  
  // Multi-Currency / Intake Audit
  originalAmount  Decimal?          @db.Decimal(12, 2)
  originalCurrency String?          @default("ETB")
  baseAmount      Decimal?          @db.Decimal(12, 2) // Converted amount for ledger posting
  
  // Donor Metadata
  donorName       String?
  donorEmail      String?
  referenceId     String?           @unique
  donorIntent     String?           @db.Text

  isRestricted    Boolean           @default(false)
  fundRestriction FundRestriction   @default(UNRESTRICTED)
  projectId       String?
  project         Project?          @relation(fields: [projectId], references: [id])
  journalEntries  ErpJournalEntry[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model ErpJournalEntry {
  id            String           @id @default(cuid())
  amount        Decimal          @db.Decimal(12, 2)
  type          JournalEntryType
  accountId     String
  account       ErpAccount       @relation(fields: [accountId], references: [id])
  transactionId String
  transaction   ErpTransaction   @relation(fields: [transactionId], references: [id])
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model InventoryItem {
  id           String         @id @default(cuid())
  name         String
  quantity     Int
  valuation    Decimal        @db.Decimal(12, 2)
  condition    AssetCondition @default(GOOD)
  location     String
  isConsumable Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Staff {
  id        String   @id @default(cuid())
  name      String
  role      String   // e.g. Teacher, Admin, Cook
  hireDate  DateTime @default(now())
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NutritionalLog {
  id           String   @id @default(cuid())
  date         DateTime @default(now())
  mealType     String   // Breakfast, Lunch
  menu         String   @db.Text
  studentCount Int      // Total students fed
  school       String   // e.g., Denbi
  absenteeIds  String[] @default([]) // Array of student IDs
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model HealthRecord {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  height    Decimal  @db.Decimal(5, 2) // cm
  weight    Decimal  @db.Decimal(5, 2) // kg
  bmi       Decimal? @db.Decimal(5, 2)
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
