{
  "name": "fregenet-itl",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build && npm run deploy:prepare",
    "start": "node server.js",
    "lint": "next lint",
    "deploy:prepare": "mkdir -p .next/standalone/public .next/standalone/.next/static && cp -r public/* .next/standalone/public/ || true && cp -r .next/static/* .next/standalone/.next/static/ || true",
    "prisma:seed": "npx tsx --env-file=.env prisma/seed.ts",
    "assets:board:prepare": "bash scripts/ensure-board-images-dir.sh",
    "assets:projects:prepare": "node scripts/ensure-project-dirs.js",
    "postinstall": "prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.5.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "lucide-react": "^0.577.0",
    "next": "15.1.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stripe": "^20.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.1.0",
    "postcss": "^8.5.8",
    "prisma": "^7.5.0",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "npx tsx --env-file=.env prisma/seed.ts"
  }
}
